# .editorconfig root=true

# Global settings for all files
[*]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
charset = utf-8
insert_final_newline = true

# JavaScript/TypeScript files
[*.{js,ts}]
quote_type = single

# HTML files
[*.html]
indent_size = 2

# CSS/SCSS files
[*.{css,scss}]
indent_size = 2
